title Containers — sluice (single Go service + supporting infrastructure)

Person(operator, "Operator / SRE", "ACT-002")
System_Ext(apiClient, "API Client", "ACT-001")

System_Boundary(sluice, "sluice (single Go process)") {
  Container(proxy, "Proxy module", "Go / net/http", "CTX-001: hot path — routing by model, cache lookup, retry(breaker.Execute), SSE proxying, cancellation, lifecycle (ADR-0006)")
  Container(resilience, "Resilience module", "Go / x/time/rate, gobreaker", "CTX-002: rate-limit middleware, worker pool backpressure, per-provider circuit breaker")
  Container(observability, "Observability module", "Go / prometheus, OTel, slog", "CTX-003: /healthz, /readyz, /metrics, tracing middleware, structured logs (ADR-0008)")
  Container(metering, "Metering module", "Go / channel + worker", "CTX-004: buffered usage channel, batch+timer flush worker (ADR-0007)")
}

System_Ext(llmProvider, "LLM Provider (mock)", "EXT-001: Provider interface — Infer / InferStream (ADR-0009)")
ContainerDb_Ext(redis, "Redis", "EXT-002: rate-limit buckets + response cache")
ContainerDb_Ext(postgres, "Postgres", "EXT-003: usage_events ledger")
System_Ext(prometheus, "Prometheus + Grafana", "EXT-004: scrape + dashboards")
System_Ext(otel, "OpenTelemetry Collector", "EXT-005")

Rel(apiClient, proxy, "POST /v1/chat/completions", "HTTPS/REST + SSE")
Rel(operator, observability, "GET /healthz, /readyz", "HTTP")

Rel(proxy, resilience, "Rate-limit check (middleware), breaker.Execute at call site", "in-process, sync (ADR-0006)")
Rel(proxy, metering, "Publishes usage event, non-blocking drop-on-full", "in-process channel (ADR-0007)")
Rel(observability, proxy, "Reads in-flight / outcomes via shared registry", "in-process (ADR-0008)")
Rel(observability, resilience, "Reads breaker_state, ratelimit_rejected_total", "in-process (ADR-0008)")
Rel(observability, metering, "Reads metering_events_dropped_total", "in-process (ADR-0008)")

Rel(proxy, llmProvider, "Infer / InferStream", "HTTPS/REST (ACL, ADR-0009)")
Rel(proxy, redis, "Cache get/set with TTL", "RESP (CacheRepository, ADR-0010)")
Rel(resilience, redis, "Distributed token buckets", "RESP (RateLimitRepository, ADR-0010)")
Rel(metering, postgres, "Batch INSERT usage_events", "SQL/pgx (MeteringRepository, ADR-0010)")
Rel(prometheus, observability, "Scrapes", "HTTP GET /metrics")
Rel(observability, otel, "Exports spans", "OTLP/HTTP")
@enduml
